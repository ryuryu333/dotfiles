{
  "provider": {
    "github": {
      "owner": "ryuryu333"
    }
  },
  "resource": {
    "github_repository": {
      "my-test-public": {
        "archive_on_destroy": true,
        "delete_branch_on_merge": true,
        "description": "動作確認用",
        "name": "my-test-public",
        "visibility": "public"
      },
      "my-test-public2": {
        "archive_on_destroy": true,
        "delete_branch_on_merge": true,
        "description": "動作確認用2",
        "name": "my-test-public2",
        "visibility": "public"
      }
    },
    "github_repository_ruleset": {
      "my-test-public-0": {
        "conditions": {
          "ref_name": {
            "include": [
              "refs/tags/v*"
            ]
          }
        },
        "enforcement": "active",
        "name": "my-test-public-0",
        "repository": "my-test-public",
        "rules": {
          "deletion": true,
          "update": true
        },
        "target": "tag"
      },
      "my-test-public-1": {
        "conditions": {
          "ref_name": {
            "include": [
              "~ALL"
            ]
          }
        },
        "enforcement": "active",
        "name": "my-test-public-1",
        "repository": "my-test-public",
        "rules": {
          "required_linear_history": true
        },
        "target": "branch"
      },
      "my-test-public-2": {
        "conditions": {
          "ref_name": {
            "include": [
              "~DEFAULT_BRANCH"
            ]
          }
        },
        "enforcement": "active",
        "name": "my-test-public-2",
        "repository": "my-test-public",
        "rules": {
          "deletion": true,
          "non_fast_forward": true,
          "pull_request": {
            "allowed_merge_methods": [
              "merge"
            ]
          },
          "required_linear_history": true
        },
        "target": "branch"
      },
      "my-test-public2-0": {
        "conditions": {
          "ref_name": {
            "include": [
              "refs/tags/v*"
            ]
          }
        },
        "enforcement": "active",
        "name": "my-test-public2-0",
        "repository": "my-test-public2",
        "rules": {
          "deletion": true,
          "update": true
        },
        "target": "tag"
      },
      "my-test-public2-1": {
        "conditions": {
          "ref_name": {
            "include": [
              "~ALL"
            ]
          }
        },
        "enforcement": "active",
        "name": "my-test-public2-1",
        "repository": "my-test-public2",
        "rules": {
          "required_linear_history": true
        },
        "target": "branch"
      },
      "my-test-public2-2": {
        "conditions": {
          "ref_name": {
            "include": [
              "~DEFAULT_BRANCH"
            ]
          }
        },
        "enforcement": "active",
        "name": "my-test-public2-2",
        "repository": "my-test-public2",
        "rules": {
          "deletion": true,
          "non_fast_forward": true,
          "pull_request": {
            "allowed_merge_methods": [
              "merge"
            ]
          },
          "required_linear_history": true
        },
        "target": "branch"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "github": {
        "source": "integrations/github",
        "version": "~> 6.0"
      }
    }
  }
}
